# Copy to .env and fill in. Source before running scripts:
#   set -a; source .env; set +a
#
# Only ONE thing you have to provide yourself. Everything else
# (kubeconfigs, Cluster B JWKS, Vault root token, MagicDNS host) is
# derived at runtime by the scripts and written to .env automatically.

# Tailscale auth key — reusable + ephemeral, tag:k8s-router.
# Generate at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX

# Playground IDs (filled by scripts/00-setup-kubeconfigs.sh after labctl start).
PLAY_A=
PLAY_B=
